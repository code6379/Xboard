APP_NAME=XBoard
APP_ENV=production
APP_KEY=base64:PZXk5vTuTinfeEVG5FpYv2l6WEhLsyvGpiWK7IgJJ60=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xboard
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME=null
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# google cloud storage
ENABLE_AUTO_BACKUP_AND_UPDATE=false
GOOGLE_CLOUD_KEY_FILE=config/googleCloudStorageKey.json
GOOGLE_CLOUD_STORAGE_BUCKET=

# Prevent reinstallation
INSTALLED=false

# 低流量用户订阅返回的固定假域名；留空表示关闭域名替换
FAKE_DOMAIN=oss-cn-guangzhou.chylink.xyz
# 连续多少个自然日每天未达到流量阈值时，返回假域名
LOW_TRAFFIC_DAYS=7
# 每日流量阈值，单位为字节；5242880 等于 5 MiB
LOW_TRAFFIC_LIMIT=5242880
# 订阅 IP/CIDR 黑名单文件，每行一个 IP 或 CIDR；支持 # 注释
SUBSCRIPTION_BLACKLIST_IP_RANGES_FILE=storage/app/subscription-blacklist-ip-ranges.txt
# 订阅邮箱黑名单文件，每行一个完整邮箱；支持 # 注释
SUBSCRIPTION_BLACKLIST_EMAILS_FILE=storage/app/subscription-blacklist-emails.txt
# 订阅域名替换白名单文件，每行一个完整邮箱；白名单优先于所有异常规则
SUBSCRIPTION_WHITELIST_EMAILS_FILE=storage/app/subscription-whitelist-emails.txt

# 接收低流量订阅告警的 Telegram 频道或群组 ID，例如：-1001234567890
TELEGRAM_ALERT_CHAT_ID=
# 同一用户的 Telegram 告警间隔，单位秒；86400 等于 24 小时
LOW_TRAFFIC_ALERT_INTERVAL=86400
